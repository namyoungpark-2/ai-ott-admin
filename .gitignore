# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.pnpm-store
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
*.lcov

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem
Thumbs.db
ehthumbs.db
Desktop.ini

# debug & logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/

# env & secrets (do not commit)
.env
.env.*
!.env.example
!.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / editor
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS & temp
*.tmp
*.temp
.cache/

# turbo (if used later)
.turbo
